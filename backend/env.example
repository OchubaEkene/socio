# ─── Server ───────────────────────────────────────────────────
PORT=5001
NODE_ENV=production
TZ=UTC

# ─── Database ─────────────────────────────────────────────────
# Neon / Supabase / Railway Postgres
DATABASE_URL="postgresql://user:password@host:5432/socio_db?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
# Your Vercel frontend URL (comma-separated for multiple)
FRONTEND_URL=https://your-app.vercel.app

# ─── Email (optional — needed for shift notifications) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@your-domain.com
